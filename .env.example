# =============================================================================
# Luftdaten API — environment template
# Copy to `.env` and fill in real values:  cp .env.example .env
# Docker Compose reads this file for ${VAR} substitution and for services
# that declare `env_file: [.env]`.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (official image: `db` service)
# Used by: db container, app (SQLAlchemy), Alembic, import scripts,
#          postgres_exporter DATA_SOURCE_URI (compose substitution).
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=postgres

# -----------------------------------------------------------------------------
# Application database connection
# In Docker Compose, the hostname is the service name of the database.
# -----------------------------------------------------------------------------
DB_HOST=db

# SQLAlchemy async QueuePool (defaults avoid exhausting 5 + overflow 10 under load)
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=40

# libpq / asyncpg application_name (visible in pg_stat_activity; default luftdaten-api)
# POSTGRES_APPLICATION_NAME=luftdaten-api

# Log every emitted SQL line to stderr (dev only; very noisy)
# DB_SQL_ECHO=true

# -----------------------------------------------------------------------------
# App (optional)
# -----------------------------------------------------------------------------
# DEBUG|INFO|WARNING|ERROR|CRITICAL
LOG_LEVEL=INFO

# Set to true to log each POST /station/data and /station/status (path + HTTP status, incl. 422)
# LOG_STATION_INGEST=true

# Override path to station blacklist JSON (default: config/station_blacklist.json in image)
# STATION_BLACKLIST_FILE=/usr/src/config/station_blacklist.json

# -----------------------------------------------------------------------------
# Monitoring — production / `example-docker-compose.prod.yml` Grafana
# (dev `docker-compose.yml` Grafana uses a fixed admin password unless you set these)
# -----------------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=change_me
GF_USERS_ALLOW_SIGN_UP="false"
# Must match the public URL (e.g. Traefik host) for correct links/redirects
GF_SERVER_ROOT_URL=https://grafana.staging.api.luftdaten.at

# -----------------------------------------------------------------------------
# pgAdmin — `example-docker-compose.prod.yml` `admin` service
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - postgres_exporter uses DATA_SOURCE_URI (host:port/db?params) plus
#   DATA_SOURCE_USER / DATA_SOURCE_PASS from this file (Compose interpolation).
#   Do not put a full postgresql:// URL into DATA_SOURCE_URI — the exporter will
#   double-wrap it and fail DNS lookup on "postgresql".
# - Optional: ENABLE_METRICS=true with prometheus-fastapi-instrumentator if you
#   enable should_respect_env_var in code (not default).
